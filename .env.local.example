# Supabase Postgres — pooled (port 6543, Supavisor transaction mode)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct (port 5432). Used only by prisma migrate.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase Auth + supabase-js
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key-from-dashboard>"

# Service role — NEVER expose to the browser. Used by Prisma operations that need to bypass RLS at signup time.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key-from-dashboard>"

# --- Speech-to-text (STT) ---
# Default is self-hosted whisper-flow on Cloud Run (family audio never leaves our infra).
STT_PROVIDER="whisperFlow"                # whisperFlow (default) | elevenlabs (fallback)
WHISPER_FLOW_URL="<cloud-run-https-url>"  # the whisper-flow service URL
WHISPER_FLOW_AUTH_TOKEN="<shared-bearer-secret>"  # same value as the Cloud Run secret

# --- ElevenLabs ---
# Still used for TTS narration (/api/voice/[scene]). STT is now whisper-flow (above);
# ElevenLabs Scribe remains only as an OFF-by-default STT fallback. Rotate any leaked key.
ELEVENLABS_API_KEY="<elevenlabs-api-key>"
# Optional: STT zero-retention (enterprise-only). Only relevant if STT_PROVIDER=elevenlabs.
ELEVENLABS_STT_ZERO_RETENTION="false"

# --- Agent (DeepSeek, OpenAI-compatible) ---
# V1 default endpoint is api.deepseek.com (PRC jurisdiction), FAMILY-ONLY.
# Migrating to a Western zero-retention host is a HARD GATE before any non-family
# user. See PlatformDocuments/PRE-PUBLIC-LAUNCH-CHECKLIST.md + ADR-001.
DEEPSEEK_API_KEY="<deepseek-api-key>"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"   # override to a Western host later
DEEPSEEK_MODEL="deepseek-chat"

# --- LangSmith tracing (DEBUG / EVAL observability for the agent) ---
# OFF by default. Onboarding turns carry dense real PII, so tracing them to
# LangSmith's US cloud is the same trust violation as the DeepSeek-PRC gate.
# RULE: trace dev + the eval harness on SYNTHETIC/REDACTED data only. Do NOT
# trace live family sessions until LangSmith is self-hosted. See ADR + checklist.
#
# Master switch. Unset/anything-but-true => zero traces (prod-safe default).
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY="<langsmith-api-key>"           # only needed when tracing on
LANGSMITH_PROJECT="nextofkin-yourlife"
# Safety: even with TRACING=true, tracing is REFUSED in production unless this is
# explicitly true. Keeps live family PII off LangSmith if the env var ever leaks.
LANGSMITH_ALLOW_PROD="false"
# Redaction is ON whenever tracing is on. Set to "false" ONLY for local dev runs
# on synthetic/your-own data where you want to read the real prompts to debug.
LANGSMITH_REDACT="true"
