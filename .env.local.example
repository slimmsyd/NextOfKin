# Supabase Postgres — pooled (port 6543, Supavisor transaction mode)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct (port 5432). Used only by prisma migrate.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase Auth + supabase-js
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key-from-dashboard>"

# Service role — NEVER expose to the browser. Used by Prisma operations that need to bypass RLS at signup time.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key-from-dashboard>"

# --- Speech-to-text (STT) ---
# Default is self-hosted whisper-flow on Cloud Run (family audio never leaves our infra).
STT_PROVIDER="whisperFlow"                # whisperFlow (default) | elevenlabs (fallback)
WHISPER_FLOW_URL="<cloud-run-https-url>"  # the whisper-flow service URL
WHISPER_FLOW_AUTH_TOKEN="<shared-bearer-secret>"  # same value as the Cloud Run secret

# --- Text-to-speech (TTS) narration ---
# Default serves pre-rendered MisoTTS clips from public/voice/{scene}.mp3 (no third party).
TTS_PROVIDER="static"                     # static (default) | elevenlabs (fallback)

# ElevenLabs — fallback only now (STT + TTS). Default OFF. Rotate any leaked key.
ELEVENLABS_API_KEY="<elevenlabs-api-key>"
# Optional: STT zero-retention (enterprise-only). Only relevant if STT_PROVIDER=elevenlabs.
ELEVENLABS_STT_ZERO_RETENTION="false"
